rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email in [
          "paradoxakka@gmail.com",
          "paradox.akka@bpc.kg",
          "kasiet.moldalieva@bpc.kg"
        ];
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /employees/{employeeId} {
      allow read: if signedIn();
      allow create: if isAdmin() || isOwner(employeeId);
      allow update: if isAdmin() || isOwner(employeeId);
      allow delete: if isAdmin();
    }

    match /requests/{requestId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if isAdmin();
    }

    match /action_logs/{logId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    match /documents/{documentId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /request_types/{requestTypeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /workflows/{workflowId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /agent_sessions/{sessionId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /agent_messages/{messageId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
